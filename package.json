{
  "name": "ACPLagunaTranslator",
  "version": "0.1.0",
  "description": "Virtuals ACP v2 provider agent that fronts the Laguna affiliate-commerce backend. Free-to-caller offerings; revenue comes from Laguna commission on resulting conversions.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild src/server.ts --bundle --platform=node --format=cjs --outfile=dist/bundle.cjs",
    "dev": "tsx watch --env-file=.env src/server.ts",
    "start": "node dist/bundle.cjs",
    "register": "tsx scripts/register-agent.ts",
    "test:handler": "tsx --env-file=.env scripts/test-handler.ts",
    "smoke": "tsx scripts/smoke-sepolia.ts",
    "typecheck": "tsc -p . --noEmit",
    "lint": "eslint src scripts --ext .ts"
  },
  "dependencies": {
    "@account-kit/infra": "^4.0.0",
    "@virtuals-protocol/acp-node-v2": "^0.1.6",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "undici": "^6.19.8",
    "viem": "^2.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "esbuild": "^0.28.0",
    "eslint": "^9.12.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20.11"
  }
}

# ─── Laguna backend ────────────────────────────────────────────────
LAGUNA_API_BASE_URL=https://agents.laguna.network/api/v1
# Laguna-registered email (stays on their side, separate from ACP email)
LAGUNA_AGENT_EMAIL=yixin@menyala.com

# ─── ACP v2 ────────────────────────────────────────────────────────
# Base EOA that is BOTH our ACP provider wallet AND our Laguna payout wallet.
ACP_WALLET_ADDRESS=0xe30fcf406e70523b63de93ef96b84d98f5511f3a
# Privy entity id (if using PrivyAlchemyEvmProviderAdapter)
ACP_ENTITY_ID=1
# Chain IDs we register against (Base Sepolia for dev, Base for prod).
ACP_CHAINS=baseSepolia,base
# ACP-side agent email — distinct from LAGUNA_AGENT_EMAIL.
ACP_AGENT_EMAIL=laguna-acp@menyala.com

# Signer strategy (pick ONE path):
#   A) dev private key (easy local testing):
ACP_SIGNER_PRIVATE_KEY=
#   B) OS keychain via acp-cli (run `npx acp agent add-signer` once — no env needed)
#   C) Privy-managed (recommended for HA / containers):
PRIVY_WALLET_ID=
PRIVY_SIGNER_PRIVATE_KEY=

# ─── Attestation ───────────────────────────────────────────────────
# ed25519 keypair base64 for signing deliverables. Generate with:
#   node -e "const n=require('tweetnacl');const k=n.sign.keyPair();console.log('PUB=',Buffer.from(k.publicKey).toString('base64'));console.log('SEC=',Buffer.from(k.secretKey).toString('base64'))"
ATTEST_PUBKEY_B64=
ATTEST_SECKEY_B64=

# ─── Ops ───────────────────────────────────────────────────────────
CACHE_DB_PATH=./var/cache.sqlite
LOG_LEVEL=info
PORT=8787
